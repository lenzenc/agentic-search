# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional — raises rate limit on pokemontcg.io from 1000/day to unlimited
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here

# Elasticsearch (defaults work with docker-compose)
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=pokemon_cards

# Agent tuning (defaults are good for demo)
MAX_RETRIEVE_ITERATIONS=3
MIN_RELEVANT_DOCS=3
TOP_K_RETRIEVE=100
SCORE_THRESHOLD_RATIO=0.4
EMBEDDING_DIM=1536
